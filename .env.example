# URL base de la API (sin barra final)
# En local: http://localhost:8002
# En producción: URL de tu servicio Render.com (ej: https://radia-api.onrender.com)
VITE_API_BASE=http://localhost:8002

# Orígenes CORS permitidos por la API (separados por comas)
# En local: * (cualquier origen)
# En producción: dominio de tu Vercel (ej: https://radia-csn.vercel.app)
ALLOWED_ORIGINS=*
